{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATH=$(cat | jq -r '.tool_input.file_path // empty') && { [[ \"$FILE_PATH\" =~ (claude-log-(failure|subagent)\\.sh|\\.claude/skills/(catchup|pre-mr)\\.md) ]] && echo 'WARNING: Template-managed file. Consider using upgrade-repo.sh instead of editing directly. Run detect-drift.sh after changes.'; [[ \"$FILE_PATH\" =~ (Podfile\\.lock|\\.pbxproj|\\.xcscheme|\\.gitlab-ci\\.ya?ml|Gemfile\\.lock|Package\\.resolved) ]] && echo 'BLOCKED: Build system or project file. Confirm with user before editing.' && exit 2; }; exit 0",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/pre-task.sh ]] && ./hooks/pre-task.sh || exit 0",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./scripts/claude-format.sh ]] && ./scripts/claude-format.sh || exit 0",
            "timeout": 10000,
            "statusMessage": "Formatting..."
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/outcome-verify.sh ]] && ./hooks/outcome-verify.sh 2>>.claude/memory/hook-errors.log || exit 0",
            "timeout": 2000,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/notify.sh ]] && ./hooks/notify.sh 'Attention' 'Claude Code needs your attention' Glass || exit 0"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/waiting-ping.sh ]] && ./hooks/waiting-ping.sh || exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/stop-gate.sh ]] && ./hooks/stop-gate.sh || exit 0",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/notify.sh ]] && ./hooks/notify.sh 'Done' 'Claude Code finished' Blow || exit 0"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review whether all tasks the user requested were completed. Check: (1) Were all requested changes made? (2) Was verification run (compile/test/lint)? (3) Are there any TODO items mentioned but not addressed? If anything is incomplete or unverified, respond with a brief summary of what remains."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./scripts/claude-post-session-analysis.sh ]] && ./scripts/claude-post-session-analysis.sh || exit 0",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/session-end-cost.sh ]] && ./hooks/session-end-cost.sh || exit 0",
            "timeout": 15000,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./scripts/claude-log-failure.sh ]] && ./scripts/claude-log-failure.sh || exit 0",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./scripts/claude-log-subagent.sh ]] && ./scripts/claude-log-subagent.sh || exit 0",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/session-start.sh ]] && ./hooks/session-start.sh || exit 0",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/session-end.sh ]] && ./hooks/session-end.sh || exit 0",
            "timeout": 30000,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/pre-compact.sh ]] && ./hooks/pre-compact.sh || exit 0",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/subagent-start.sh ]] && ./hooks/subagent-start.sh || exit 0",
            "timeout": 2000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/task-completed.sh ]] && ./hooks/task-completed.sh || exit 0",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/cancel-waiting.sh ]] && ./hooks/cancel-waiting.sh || exit 0"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/context-refresh.sh ]] && ./hooks/context-refresh.sh || exit 0",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -x ./hooks/auto-activate.sh ]] && ./hooks/auto-activate.sh || exit 0",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
